# ── macOS ──────────────────────────────────────────────
.DS_Store

# ── Xcode build & derived data ─────────────────────────
build/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM
*.dSYM.zip

# ── Xcode user-specific state (never share) ────────────
xcuserdata/
*.xcuserstate
*.xcuserdatad
*.xccheckout
*.xcscmblueprint

# ── Swift Package Manager (keep the *shared* Package.resolved) ──
.swiftpm/
.build/

# ── Claude Code local config / worktrees (any level) ───
.claude/*
# …but track the shared session-start hook so all sessions get the clash check
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json

# ── Python (tools/ synthetic-data generators) ──────────
__pycache__/
*.pyc

# ── Editors / misc ─────────────────────────────────────
*.swp
*~
.idea/
.vscode/
